{
  "properties": [
    {
      "name": "letool.cache.enabled",
      "type": "java.lang.Boolean",
      "description": "缓存模块总开关。",
      "defaultValue": "true"
    },
    {
      "name": "letool.cache.redis-prefix",
      "type": "java.lang.String",
      "description": "Redis key 前缀。",
      "defaultValue": "letool:cache:"
    },
    {
      "name": "letool.cache.instances.name",
      "type": "java.lang.String",
      "description": "单个缓存实例的名称标识。"
    },
    {
      "name": "letool.cache.instances.l1-max-size",
      "type": "java.lang.Integer",
      "description": "一级缓存（Caffeine）最大条目数。",
      "defaultValue": "2000"
    },
    {
      "name": "letool.cache.instances.l1-ttl",
      "type": "java.time.Duration",
      "description": "一级缓存（Caffeine）过期时间。",
      "defaultValue": "86400s"
    },
    {
      "name": "letool.cache.instances.l2-ttl",
      "type": "java.time.Duration",
      "description": "二级缓存（Redis）过期时间。",
      "defaultValue": "259200s"
    },
    {
      "name": "letool.cache.instances.null-value-cache",
      "type": "java.lang.Boolean",
      "description": "是否缓存 null 值（防止缓存穿透）。",
      "defaultValue": "true"
    },
    {
      "name": "letool.cache.instances.null-value-ttl",
      "type": "java.time.Duration",
      "description": "Null 值缓存过期时间。",
      "defaultValue": "300s"
    },
    {
      "name": "letool.cache.degradation.recovery-interval",
      "type": "java.time.Duration",
      "description": "L2 降级健康检查间隔。",
      "defaultValue": "30s"
    },
    {
      "name": "letool.cache.degradation.max-retry-count",
      "type": "java.lang.Integer",
      "description": "降级恢复最大重试次数。",
      "defaultValue": "3"
    },
    {
      "name": "letool.cache.monitoring.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用缓存监控。",
      "defaultValue": "true"
    }
  ]
}
