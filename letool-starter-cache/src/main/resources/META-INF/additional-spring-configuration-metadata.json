{
  "properties": [
    {
      "name": "letool.cache.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable the cache starter.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.redis-prefix",
      "type": "java.lang.String",
      "description": "Global Redis key prefix for cache data.",
      "defaultValue": "letool:cache:"
    },
    {
      "name": "letool.cache.l1-enabled",
      "type": "java.lang.Boolean",
      "description": "Global switch for Caffeine L1 cache.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.l2-enabled",
      "type": "java.lang.Boolean",
      "description": "Global switch for Redis L2 cache.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.strong-consistency",
      "type": "java.lang.Boolean",
      "description": "Verify Redis cache-region versions before returning L1 hits.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.instances.name",
      "type": "java.lang.String",
      "description": "Cache instance name."
    },
    {
      "name": "letool.cache.instances.l1-enabled",
      "type": "java.lang.Boolean",
      "description": "Per-cache L1 switch.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.instances.l1-max-size",
      "type": "java.lang.Integer",
      "description": "Maximum Caffeine L1 entries.",
      "defaultValue": 2000
    },
    {
      "name": "letool.cache.instances.l1-ttl",
      "type": "java.time.Duration",
      "description": "L1 cache TTL.",
      "defaultValue": "86400s"
    },
    {
      "name": "letool.cache.instances.l2-enabled",
      "type": "java.lang.Boolean",
      "description": "Per-cache L2 switch.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.instances.l2-ttl",
      "type": "java.time.Duration",
      "description": "Redis L2 cache TTL.",
      "defaultValue": "259200s"
    },
    {
      "name": "letool.cache.instances.strong-consistency",
      "type": "java.lang.Boolean",
      "description": "Per-cache strong consistency switch.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.instances.null-value-cache",
      "type": "java.lang.Boolean",
      "description": "Cache null loader results to prevent cache penetration.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.instances.null-value-ttl",
      "type": "java.time.Duration",
      "description": "Null sentinel TTL.",
      "defaultValue": "300s"
    },
    {
      "name": "letool.cache.invalidation.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable Redis pub/sub L1 invalidation.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.invalidation.channel",
      "type": "java.lang.String",
      "description": "Redis pub/sub channel for L1 invalidation.",
      "defaultValue": "letool:cache:invalidation"
    },
    {
      "name": "letool.cache.degradation.recovery-enabled",
      "type": "java.lang.Boolean",
      "description": "Enable periodic L2 recovery checks.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.degradation.recovery-interval",
      "type": "java.time.Duration",
      "description": "L2 recovery check interval.",
      "defaultValue": "30s"
    },
    {
      "name": "letool.cache.monitoring.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable cache monitoring bean.",
      "defaultValue": true
    },
    {
      "name": "letool.cache.annotation.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable annotation-driven cache aspect.",
      "defaultValue": true
    }
  ]
}
